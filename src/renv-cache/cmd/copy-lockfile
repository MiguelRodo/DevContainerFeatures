#!/usr/bin/env bash

set -e

CACHE_DIR="/usr/local/share/renv-cache/lockfiles"
TARGET_PATH="./renv.lock"
OVERWRITE=false
PREFER_UPDATE=false
ACTION="copy"
SELECTED_PROJECT="_unified"

usage() {
    echo "Usage: renv-cache-copy-lockfile [OPTIONS] [PATH]"
    echo ""
    echo "Copies a cached renv.lock file to your working directory."
    echo ""
    echo "Arguments:"
    echo "  PATH                     Destination path (default: ./renv.lock)"
    echo ""
    echo "Options:"
    echo "  --list                   List all available cached projects and their lockfile states."
    echo "  -p, --project <name>     Specify a specific project to copy instead of the unified one."
    echo "                           (Use --list to see available names. Default: renv-cache-unified)"
    echo "  --update                 Prefer the updated lockfile over the originally restored one."
    echo "  --overwrite              Overwrite the destination file if it already exists."
    echo "  -h, --help               Show this help message."
    exit 0
}

while [[ "$#" -gt 0 ]]; do
    case $1 in
        --list) ACTION="list"; shift ;;
        -p|--project) SELECTED_PROJECT="$2"; shift 2 ;;
        --update) PREFER_UPDATE=true; shift ;;
        --overwrite) OVERWRITE=true; shift ;;
        -h|--help) usage ;;
        -*) echo "[ERROR] Unknown option: $1"; exit 1 ;;
        *) TARGET_PATH="$1"; shift ;;
    esac
done

if [ ! -d "$CACHE_DIR" ]; then
    echo "[INFO] Internal cache directory not found: $CACHE_DIR"
    exit 0
fi

# ==========================================
# ACTION: LIST
# ==========================================
if [ "$ACTION" = "list" ]; then
    echo "Available cached lockfiles:"
    echo "--------------------------------------------------------"
    for proj_dir in "$CACHE_DIR"/*; do
        if [ -d "$proj_dir" ]; then
            proj_name=$(basename "$proj_dir")
            
            if [ "$proj_name" = "_unified" ]; then
                echo "📦 renv-cache-unified [DEFAULT PROJECT]"
                echo "   (Unified lockfile containing all dependencies)"
            else
                echo "📁 Project: $proj_name"
            fi

            if [ -f "$proj_dir/restore/renv.lock" ]; then
                echo "   - Restored state available (Original)"
            fi
            if [ -f "$proj_dir/update/renv.lock" ]; then
                echo "   - Updated state available (--update)"
            fi
            echo ""
        fi
    done
    echo "--------------------------------------------------------"
    echo "Run 'renv-cache-copy-lockfile' to copy the default unified project."
    echo "Run 'renv-cache-copy-lockfile --project <name>' to copy a specific project."
    exit 0
fi

# ==========================================
# ACTION: COPY
# ==========================================
if [ "$ACTION" = "copy" ]; then
    # If the provided path is a directory, append /renv.lock
    if [ -d "$TARGET_PATH" ]; then
        TARGET_PATH="${TARGET_PATH%/}/renv.lock"
    fi

    # Check for existence and --overwrite flag
    if [ -f "$TARGET_PATH" ] && [ "$OVERWRITE" = "false" ]; then
        echo "[ERROR] File '$TARGET_PATH' already exists."
        echo "To overwrite, use the --overwrite flag:"
        echo "  renv-cache-copy-lockfile \"$TARGET_PATH\" --overwrite"
        exit 1
    fi

    # Map user-friendly name back to the internal folder
    if [ "$SELECTED_PROJECT" = "renv-cache-unified" ]; then
        SELECTED_PROJECT="_unified"
    fi

    # Smart Fallback: If they requested the unified file but it doesn't exist
    # (e.g. they opted out), check if there is exactly ONE project available.
    if [ "$SELECTED_PROJECT" = "_unified" ] && [ ! -d "$CACHE_DIR/_unified" ]; then
        PROJ_COUNT=$(find "$CACHE_DIR" -mindepth 1 -maxdepth 1 -type d | wc -l)
        if [ "$PROJ_COUNT" -eq 1 ]; then
            SELECTED_PROJECT=$(basename "$(find "$CACHE_DIR" -mindepth 1 -maxdepth 1 -type d)")
            echo "[INFO] Unified lockfile disabled, but only one project exists."
            echo "       Automatically defaulting to project: '$SELECTED_PROJECT'."
        fi
    fi

    PROJ_DIR="$CACHE_DIR/$SELECTED_PROJECT"

    if [ ! -d "$PROJ_DIR" ]; then
        echo "[ERROR] Project '$SELECTED_PROJECT' not found in cache."
        echo "Run 'renv-cache-copy-lockfile --list' to see available projects."
        exit 1
    fi

    RESTORE_FILE="$PROJ_DIR/restore/renv.lock"
    UPDATE_FILE="$PROJ_DIR/update/renv.lock"

    if [ ! -f "$RESTORE_FILE" ] && [ ! -f "$UPDATE_FILE" ]; then
        echo "[ERROR] No renv.lock files were cached for project '$SELECTED_PROJECT'."
        exit 1
    fi

    SOURCE_FILE=""
    DISPLAY_NAME=$([ "$SELECTED_PROJECT" = "_unified" ] && echo "renv-cache-unified" || echo "$SELECTED_PROJECT")

    # Handle Update Preference
    if [ "$PREFER_UPDATE" = "true" ]; then
        if [ -f "$UPDATE_FILE" ]; then
            SOURCE_FILE="$UPDATE_FILE"
            echo "[INFO] Selected updated lockfile for '$DISPLAY_NAME'."
        elif [ -f "$RESTORE_FILE" ]; then
            SOURCE_FILE="$RESTORE_FILE"
            echo "[WARN] --update specified, but no updated lockfile found."
            echo "       Using original restored state instead."
        fi
    else
        # Handle Default (Original Restore Preference)
        if [ -f "$RESTORE_FILE" ]; then
            SOURCE_FILE="$RESTORE_FILE"
            echo "[INFO] Selected original (restored) lockfile for '$DISPLAY_NAME'."
        elif [ -f "$UPDATE_FILE" ]; then
            SOURCE_FILE="$UPDATE_FILE"
            echo "[INFO] Original restored lockfile not found."
            echo "       Using updated lockfile instead."
        fi
    fi

    # Ensure parent directories exist
    mkdir -p "$(dirname "$TARGET_PATH")"

    # Execute the copy
    cp "$SOURCE_FILE" "$TARGET_PATH"
    echo "[OK] Successfully copied lockfile to $TARGET_PATH"
fi
